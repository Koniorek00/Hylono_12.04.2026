{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["node"],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "dist-ssr",
    /* ── Archive / Backup directories ─────────────────────────────────────── */
    /* These contain outdated code with broken imports. They are intentionally  */
    /* excluded from compilation — see .gitignore for matching entries.         */
    "backups",
    "protected-ui-backup-2026-02-16",
    "compressed-web",
    "sandbox",
    "artifacts",
    /* ── Unused / experimental components ──────────────────────────────────── */
    "components/_unused",
    "components/Hero45",
    "components/Hero46",
    "components/Hero46T2",
    "components/HeroGPT",
    "components/MegaMenu.backup.tsx",
    "components/TechDetail.backup.tsx",
    /* ── Prisma RBAC helper — requires generated client (run `prisma generate`) ── */
    "lib/rbac",
    /* ── E2E tests + playwright config — require @playwright/test which is not in devDependencies ── */
    "e2e",
    "playwright.config.ts",
    /* ── Separate Next.js workspace (validated independently) ────────────── */
    "control-panel",
    /* Vendored third-party workspaces are not part of the app TypeScript program. */
    "docker/phase-1a/vendor"
  ],
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next-check/types/**/*.ts",
    ".next-check/dev/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ]
}
