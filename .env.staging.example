# Staging environment template for Hylono
# Copy to .env.staging and replace every placeholder before provisioning a server.

# Base URLs
PUBLIC_SITE_URL=https://staging.hylono.com
NEXT_PUBLIC_API_BASE_URL=https://api.staging.hylono.com
NEXT_PUBLIC_CONTROL_PANEL_URL=https://ops.staging.hylono.com/admin/stack
TWENTY_API_BASE_URL=https://crm.staging.hylono.com
NOVU_API_BASE_URL=https://novu.staging.hylono.com
NOVU_WORKFLOW_ID=powiadomienia

# Public service URLs expected by the apps
MEDUSA_PUBLIC_URL=https://medusa.staging.hylono.com
LAGO_API_URL=https://lago-api.staging.hylono.com
LAGO_FRONT_URL=https://lago.staging.hylono.com
