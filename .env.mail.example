# ─── Mail delivery profile ───
# local-safe = no external app-mail delivery yet
# resend-novu = app mailers use Resend, Novu uses Custom SMTP
# shared-smtp = app mailers and Novu both use the same SMTP provider
MAIL_PROVIDER_PROFILE=local-safe

# Canonical sender identity
MAIL_FROM_NAME=Hylono
MAIL_FROM_EMAIL=notifications@hylono.com
MAIL_REPLY_TO_EMAIL=support@hylono.com

# ─── App mailers ───
# App routes currently use Resend when this key exists.
MAIL_APP_MODE=console
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=notifications@hylono.com

# Shared SMTP transport for app mailers
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Hylono
SMTP_FROM_EMAIL=notifications@hylono.com

# ─── Novu sync / workflow trigger ───
NOVU_API_BASE_URL=http://localhost:18110
NOVU_API_SECRET=
NOVU_WORKFLOW_ID=powiadomienia

# ─── Novu email channel ───
# in-app = keep workflows local and in-app only
# custom-smtp = use Novu's Custom SMTP integration
NOVU_EMAIL_MODE=in-app
NOVU_EMAIL_FROM_NAME=Hylono
NOVU_EMAIL_FROM_EMAIL=notifications@hylono.com
NOVU_SMTP_HOST=
NOVU_SMTP_PORT=587
NOVU_SMTP_SECURE=false
NOVU_SMTP_USER=
NOVU_SMTP_PASSWORD=

# Optional DKIM fields for Novu SMTP
NOVU_DKIM_DOMAIN=
NOVU_DKIM_KEY_SELECTOR=
NOVU_DKIM_PRIVATE_KEY=

# Local operator test recipient
MAIL_TEST_TO=ops@hylono.com

