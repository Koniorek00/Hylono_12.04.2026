// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- PARTNER HUB SCHEMA ---

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum Modality {
  HBOT
  PEMF
  RLT
  HYDROGEN
}

model Clinic {
  id        String   @id @default(uuid())
  name      String
  legalName String?
  vatId     String?
  address   String?
  logoUrl   String?
  brandColor String  @default("#0ea5e9")
  website   String?
  bookingUrl String?
  
  users     User[]
  devices   DeviceFleet[]
  referrals Referral[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  password  String   // Hashed
  role      UserRole @default(STAFF)
  
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  
  trainings TrainingProgress[]
  
  createdAt DateTime @default(now())
}

model DeviceFleet {
  id            String   @id @default(uuid())
  serialNumber  String   @unique
  modality      Modality
  modelName     String
  purchaseDate  DateTime
  warrantyEnd   DateTime
  
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  
  serviceLogs   ServiceLog[]
  
  status        String   @default("ACTIVE") // ACTIVE, MAINTENANCE, RETIRED
}

model ServiceLog {
  id          String   @id @default(uuid())
  description String
  date        DateTime @default(now())
  type        String   // ROUTINE, REPAIR, ISSUE
  
  deviceId    String
  device      DeviceFleet @relation(fields: [deviceId], references: [id])
}

model TrainingModule {
  id          String   @id @default(uuid())
  title       String
  description String
  videoUrl    String
  durationMin Int
  level       Int      // 1: Operator, 2: Specialist, 3: Master
  modality    Modality
  
  progress    TrainingProgress[]
}

model TrainingProgress {
  id          String   @id @default(uuid())
  completed   Boolean  @default(false)
  score       Int?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  moduleId    String
  module      TrainingModule @relation(fields: [moduleId], references: [id])
  
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, moduleId])
}

model Referral {
  id          String   @id @default(uuid())
  patientName String?
  patientEmail String?
  status      String   @default("PENDING") // PENDING, CONVERTED, PAID
  commission  Float    @default(0.0)
  
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  
  createdAt   DateTime @default(now())
}
