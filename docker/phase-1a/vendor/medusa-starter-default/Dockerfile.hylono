FROM node:20-bookworm-slim

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY . .

RUN corepack enable && yarn install --immutable
RUN yarn build

EXPOSE 9000

CMD ["sh", "./docker/start-medusa.sh"]
