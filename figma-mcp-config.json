{
  "mcpServers": {
    "github.com/GLips/Figma-Context-MCP": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key=YOUR_FIGMA_API_KEY",
        "--stdio"
      ],
      "env": {
        "FIGMA_API_KEY": "YOUR_FIGMA_API_KEY"
      },
      "disabled": false,
      "autoApprove": [
        "get_figma_data",
        "download_figma_images"
      ],
      "timeout": 120,
      "type": "stdio"
    }
  }
}
