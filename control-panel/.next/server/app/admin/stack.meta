{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/stack/layout,_N_T_/admin/stack/page,_N_T_/admin/stack"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/stack/__PAGE__",
    "/admin/stack",
    "/admin",
    "/_index",
    "/_head"
  ]
}