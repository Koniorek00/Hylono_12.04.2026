e:["$","details","Docker says 'port already in use'. What do I do?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"Docker says 'port already in use'. What do I do?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"Another process is using that port. Find it with: lsof -i :5432 (Mac/Linux) or netstat -ano | findstr 5432 (Windows). Either stop that process, or change the port mapping in the relevant docker-compose.yml file (e.g. change '5432:5432' to '5433:5432')."}]]}]
f:["$","details","Services start but immediately exit. What's wrong?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"Services start but immediately exit. What's wrong?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"Check the logs: docker compose -f docker/infrastructure/docker-compose.yml logs [service-name]. Common causes: (1) missing environment variable — check your .env file has all required vars, (2) not enough memory — ensure Docker has at least 4GB RAM allocated in Docker Desktop settings, (3) port conflict (see above)."}]]}]
10:["$","details","How do I see which services are running?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"How do I see which services are running?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"Run: docker compose -f docker/infrastructure/docker-compose.yml ps\nFor Phase 1A: docker compose -f docker/phase-1a/docker-compose.yml ps\nOr open Uptime Kuma at http://localhost:3001 — it monitors all services with a visual dashboard."}]]}]
11:["$","details","What is n8n and why is it important?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"What is n8n and why is it important?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"n8n is the automation engine that connects all other services together. Most of the 27 integration flows (like 'when a new order is placed in Medusa, create an invoice in Lago') run through n8n. It's the glue of the stack. Access it at http://localhost:5678 after starting Phase 1A."}]]}]
12:["$","details","What is Zitadel?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"What is Zitadel?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"Zitadel is the Identity and Access Management (IAM) service — it handles login, user accounts, permissions, and Single Sign-On (SSO) for all Hylono services. Think of it as the authentication backbone. All other services rely on it for login. Set it up first in Phase 1A."}]]}]
13:["$","details","How do I back up my data?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"How do I back up my data?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"Run: bash scripts/backup.sh\nThis creates a timestamped folder at /backups/hylono/YYYY-MM-DD/ containing a compressed PostgreSQL dump and a Redis snapshot. Schedule this daily via cron: 0 2 * * * cd /path/to/hylono && bash scripts/backup.sh"}]]}]
14:["$","details","What's the difference between Phase 1A, 1B, 1C, and Phase 2?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"What's the difference between Phase 1A, 1B, 1C, and Phase 2?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"The phases define the deployment order based on dependencies and priority:\n• Infrastructure: database, cache, storage — must be first\n• Phase 1A: core business (commerce, fleet, CRM, auth) — start here\n• Phase 1B: IoT, AI, education, telehealth — add when ready\n• Phase 1C: marketing, advanced platform, security monitoring\n• Phase 2: 28 recommended additions — deploy as needed, in any order"}]]}]
15:["$","details","Can I run only some services instead of everything?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"Can I run only some services instead of everything?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"Yes. Each service in docker-compose.yml is independent. You can start individual services with: docker compose -f docker/phase-1a/docker-compose.yml up -d medusa lago\nJust make sure the infrastructure layer is running first (postgres, redis, minio)."}]]}]
16:["$","details","How do I update a service to a newer version?",{"className":"bg-gray-900 border border-gray-800 rounded-xl group","children":[["$","summary",null,{"className":"px-4 py-3.5 cursor-pointer text-sm font-medium text-gray-200 hover:text-white list-none flex items-center justify-between gap-2 select-none","children":[["$","span",null,{"children":"How do I update a service to a newer version?"}],["$","span",null,{"className":"text-gray-600 flex-shrink-0 group-open:rotate-180 transition-transform","children":"▼"}]]}],["$","div",null,{"className":"px-4 pb-4 pt-0 text-sm text-gray-400 leading-relaxed whitespace-pre-line border-t border-gray-800","children":"1. Pull the latest image: docker compose -f docker/[phase]/docker-compose.yml pull [service]\n2. Recreate the container: docker compose -f docker/[phase]/docker-compose.yml up -d [service]\nAlways check the service's changelog before upgrading — some updates require database migrations."}]]}]
17:["$","div",null,{"className":"mb-8","children":[["$","h2",null,{"className":"text-base font-semibold text-gray-200 mb-4 pb-2 border-b border-gray-800","children":"Glossary"}],["$","div",null,{"className":"space-y-2","children":[["$","div","Docker",{"className":"bg-gray-900 border border-gray-800 rounded-xl px-4 py-3 flex gap-3","children":[["$","span",null,{"className":"font-mono font-semibold text-cyan-400 text-sm flex-shrink-0 w-28","children":"Docker"}],["$","span",null,{"className":"text-sm text-gray-400","children":"A tool that packages software into containers — isolated, reproducible environments. Each service runs in its own container."}]]}],["$","div","Docker Compose",{"className":"bg-gray-900 border border-gray-800 rounded-xl px-4 py-3 flex gap-3","children":[["$","span",null,{"className":"font-mono font-semibold text-cyan-400 text-sm flex-shrink-0 w-28","children":"Docker Compose"}],["$","span",null,{"className":"text-sm text-gray-400","children":"A tool for defining and running multiple Docker containers together. The docker-compose.yml files describe how to start all services."}]]}],["$","div","PostgreSQL",{"className":"bg-gray-900 border border-gray-800 rounded-xl px-4 py-3 flex gap-3","children":[["$","span",null,{"className":"font-mono font-semibold text-cyan-400 text-sm flex-shrink-0 w-28","children":"PostgreSQL"}],["$","span",null,{"className":"text-sm text-gray-400","children":"The main relational database. Almost every service stores its data here in its own dedicated database."}]]}],["$","div","Redis",{"className":"bg-gray-900 border border-gray-800 rounded-xl px-4 py-3 flex gap-3","children":[["$","span",null,{"className":"font-mono font-semibold text-cyan-400 text-sm flex-shrink-0 w-28","children":"Redis"}],["$","span",null,{"className":"text-sm text-gray-400","children":"A fast in-memory cache and message broker. Used for sessions, queues, and real-time data by multiple services."}]]}],["$","div","MinIO",{"className":"bg-gray-900 border bo